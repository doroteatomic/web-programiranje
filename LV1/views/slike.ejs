<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galerija</title>

    <!-- VAŽNO: mora odgovarati točno nazivu foldera -->
    <link rel="stylesheet" href="/styles/style_slike.css">
</head>
<body>

    <header>
        <h1>Galerija Filmova</h1>
        <nav aria-label="Glavna navigacija">
            <ul class="nav-menu">
                <li><a href="/">Početna</a></li>
                <li><a href="/grafikon.html">Grafikon</a></li>
                <li><a href="/slike">Galerija</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <!-- GALERIJA -->
        <section class="galerija">
            <% images.forEach(image => { %>
                <figure class="galerija_slika">
                    <a href="#<%= image.id %>">
                        <img src="<%= image.url %>" alt="<%= image.title %>">
                    </a>
                    <figcaption><%= image.title %></figcaption>
                </figure>
            <% }) %>
        </section>

        <!-- LIGHTBOX -->
        <% images.forEach(image => { %>
            <div id="<%= image.id %>" class="lightbox">
                <a href="/slike" class="lightbox-close">×</a>
                <img src="<%= image.url %>" alt="<%= image.title %>">
                <p><%= image.title %></p>
            </div>
        <% }) %>
    </main>

</body>
</html>
